# Server Configuration
PORT=5000

# MongoDB Connection
# For local development, use mongodb://localhost:27017/healio
# For MongoDB Atlas, use your Atlas connection string
MONGODB_URI=mongodb://localhost:27017/healio

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL (for CORS)
# In development: http://localhost:3000
# In production: your deployed frontend URL
CLIENT_URL=http://localhost:3000

# Edamam Recipe API Credentials
# Sign up at https://developer.edamam.com/
EDAMAM_APP_ID=your_edamam_app_id
EDAMAM_APP_KEY=your_edamam_app_key

# Google OAuth Client ID
# Get from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
